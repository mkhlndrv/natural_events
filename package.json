{
  "name": "terrawatch",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:react": "npm run dev -w apps/react",
    "dev:vue": "npm run dev -w apps/vue",
    "build:react": "npm run build -w apps/react",
    "build:vue": "npm run build -w apps/vue",
    "lint": "eslint 'apps/*/src/**/*.{ts,tsx,vue}'",
    "format": "prettier --write 'apps/*/src/**/*.{ts,tsx,vue,css,json}'",
    "format:check": "prettier --check 'apps/*/src/**/*.{ts,tsx,vue,css,json}'",
    "test:react": "npm run test -w apps/react",
    "test:vue": "npm run test -w apps/vue",
    "test": "npm run test:react && npm run test:vue",
    "storybook:react": "npm run storybook -w apps/react",
    "storybook:vue": "npm run storybook -w apps/vue",
    "analyze:react": "ANALYZE=true npm run build -w apps/react",
    "analyze:vue": "ANALYZE=true npm run build -w apps/vue",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
